APP_NAME="LMS Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=lms_platform
DB_USERNAME=lms_user
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# SMS OTP Configuration
SMS_PROVIDER=africastalking
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=LMSPlatform
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5

# Telebirr Payment Configuration
TELEBIRR_APP_ID=
TELEBIRR_APP_KEY=
TELEBIRR_SHORT_CODE=
TELEBIRR_PUBLIC_KEY=
TELEBIRR_API_URL=https://app.ethiomobilemoney.et:2121/ammapi/payment/service-openup/toTradeWebPay
TELEBIRR_NOTIFY_URL=${APP_URL}/api/payments/telebirr/webhook
TELEBIRR_RETURN_URL=${APP_URL}/payment/return
TELEBIRR_TIMEOUT_URL=${APP_URL}/payment/timeout

# File Storage
MEDIA_DISK=local
MAX_VIDEO_SIZE=512000

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@lmsplatform.com"
MAIL_FROM_NAME="${APP_NAME}"
